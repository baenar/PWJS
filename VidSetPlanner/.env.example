# VidSetPlanner environment configuration example
# Copy this file to .env and fill only the values you actually use.
# The core app, unit tests, SQLite persistence, and Slick tests should work without Google Calendar configured.

# Optional: Google Calendar integration
# Path inside your local machine/container to a Google service account credentials JSON file.
# Example on Windows when mounted through Docker may need a /workspace-relative path.
GOOGLE_CALENDAR_KEY=/workspace/secrets/google-service-account.json

# Optional: Calendar ID or email used by Google Calendar integration.
GOOGLE_CALENDAR_EMAIL=your-calendar-id@example.com

# Optional: override SQLite database URL.
# Leave empty/default for normal local app usage.
# VSP_DB_URL=jdbc:sqlite:vidsetplanner.db
